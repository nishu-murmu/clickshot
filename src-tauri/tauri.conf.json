{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clickshot",
  "version": "0.0.1",
  "identifier": "com.nishu.clickshot",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "hidden-overlay",
        "create": true,
        "visible": false,
        "url": "hidden.html",
        "height": 600,
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "msi",
      "nsis",
      "app",
      "dmg",
      "rpm"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/README.md": "../README.md",
          "/usr/assets": "../dist/assets/"
        }
      }
    }
  }
}
